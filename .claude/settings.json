{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "memento": {
      "source": {
        "source": "github",
        "repo": "goplemms/memento"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": [
    {
      "marketplace": "memento",
      "plugin": "memento"
    }
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
